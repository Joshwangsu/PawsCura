{
  "expo": {
    "name": "PawsCura",
    "slug": "pawscura",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pawscura.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F9FA"
      },
      "package": "com.pawscura.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAgT-OYRquR2SpMJoKjWX0_IwP3bEoGzzU"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8F9FA",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ]
    ]
  }
}
